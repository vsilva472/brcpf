{
  "name": "vsilva472/brcpf",
  "description": "Brazilian CPF validation rule for Laravel (supports formatted and unformatted CPF)",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "cpf",
    "brazil",
    "validation",
    "cpf validation",
    "laravel cpf",
    "brazilian cpf",
    "laravel validation rule"
  ],
  "autoload": {
    "psr-4": {
      "Vsilva472\\BrCpf\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.1",
    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
    "vsilva472/phpcpf": "^1.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Vsilva472\\BrCpf\\Providers\\BrCpfServiceProvider"
      ]
    }
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
  }
}
